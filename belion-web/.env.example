TZ=UTC
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
APP_KEY=
NODE_ENV=production
SESSION_DRIVER=cookie

# Database: sqlite (local/dev) or postgres (Docker/Coolify production)
DB_CONNECTION=sqlite
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# PostgreSQL credentials for docker-compose (copy to .env when using compose)
POSTGRES_USER=belion
POSTGRES_PASSWORD=change-me
POSTGRES_DB=belion

# Mail (contact form notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=sales@beliongroupe.com
CONTACT_NOTIFY_EMAIL=sales@beliongroupe.com
